generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())

  sessions  Session[]
}

model Session {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  startTime     DateTime @default(now())
  endTime       DateTime?
  createdAt     DateTime @default(now())
  focusScore    Float    @default(0)
  burnoutScore  Float    @default(0)
  deepWorkScore Float    @default(0)
  entropyScore  Float    @default(0)
  switchCount   Int      @default(0)
  idleTime      Int      @default(0)
  totalDuration Int      @default(0)
  productivityScore Float @default(0)

  isDeepWork    Boolean  @default(false)

  activities    Activity[]

  @@index([userId])
  @@index([startTime])
}

model AppCategory {
  id        String   @id @default(uuid())
  appName   String   @unique
  category  String   // productive | neutral | distracting
  createdAt DateTime @default(now())
}


model Activity {
  id              String   @id @default(uuid())
  session         Session  @relation(fields: [sessionId], references: [id])
  sessionId       String

  appName         String
  windowTitle     String

  startTime       DateTime
  endTime         DateTime
  duration        Int
  type            String?

  category        String?     // deep_work, communication, etc
  intent          String?     // debugging, coordination, etc
  focusImpact     Float?      // 0–1
  energyImpact    Float?      // -1 to 1
  confidence      Float?

  @@index([sessionId])
  @@index([startTime])
}
model AppPattern {
  id          String   @id @default(uuid())
  appName     String
  titleRegex  String
  category    String
  intent      String?
  focusImpact Float?
  energyImpact Float?
  confidence  Float?
  createdAt   DateTime @default(now())

  @@index([appName])
}